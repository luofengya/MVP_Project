        <div>&nbsp;&nbsp;{</div>
        <div>&nbsp;&nbsp;&nbsp;temp_int =3D (unsigned char) *buffer++;</div=
>
        <div>&nbsp;&nbsp;&nbsp;crc ^=3D temp_int;</div>
        <div>&nbsp;&nbsp;&nbsp;for ( j =3D 0; j &lt; 8; j++ )</div>
        <div>&nbsp;&nbsp;&nbsp;&nbsp;{</div>
